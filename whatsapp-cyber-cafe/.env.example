# Server Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database Connections
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cybercafe
# Replace with your actual Redis connection string
REDIS_URL=redis://localhost:6379

# Meta/WhatsApp API Credentials
# Get these from the Meta for Developers Dashboard
WHATSAPP_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=1234567890
VERIFY_TOKEN=your_secure_verify_token_here
